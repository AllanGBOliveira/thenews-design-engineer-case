{
  "name": "thenews-design-engineer-case",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "build:ssr": "react-router build",
    "build:spa": "RENDER_MODE=spa react-router build",
    "build:ssg": "RENDER_MODE=ssg react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "start:ssr": "react-router-serve ./build/server/index.js",
    "preview": "npx serve@14 build/client -s -p 4173",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"app/**/*.scss\" --allow-empty-input",
    "lint:styles:fix": "stylelint \"app/**/*.scss\" --fix --allow-empty-input",
    "test": "vitest run",
    "test:watch": "vitest",
    "pwa:generate": "pwa-assets-generator --config pwa-assets.config.ts",
    "deploy": "npm run lint:fix && npm run lint:styles:fix && npm run pwa:generate && npm run typecheck && npm run build",
    "deploy:spa": "npm run lint:fix && npm run lint:styles:fix && npm run pwa:generate && npm run typecheck && npm run build:spa",
    "deploy:ssg": "npm run lint:fix && npm run lint:styles:fix && npm run pwa:generate && npm run typecheck && npm run build:ssg",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@react-router/node": "8.0.0",
    "@react-router/serve": "8.0.0",
    "@unpic/react": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "isbot": "^5.1.36",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-lite-youtube-embed": "^3.6.0",
    "react-router": "8.0.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.1.3",
    "@rolldown/binding-linux-x64-musl": "1.1.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint-react/eslint-plugin": "^5.9.5",
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "8.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
