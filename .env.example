# Server port (used by Docker; Vite dev defaults to 5173, production server defaults to 3000)
PORT=5173

# Client-side variables must be prefixed with VITE_

# Site identity — used to derive appSlug (e.g. "thenews" → slug "thenews")
VITE_SITE_NAME=thenews
VITE_SITE_URL=https://thenewscc.com.br
VITE_SITE_SHORT_NAME=thenews
VITE_SITE_DESCRIPTION=the news — design engineer case

# Theme colors (hex) — also used in the PWA manifest
VITE_THEME_COLOR="#000000"
VITE_BG_COLOR="#ffffff"

# i18n — cookie key defaults to "${appSlug}-i18n" if not set
# VITE_I18N_COOKIE_KEY=thenews-i18n

# Theme — cookie name defaults to "${appSlug}-theme" if not set
# VITE_THEME_COOKIE_KEY=thenews-theme


# ─── Build-time only (no VITE_ prefix — not exposed to client) ───────────────

# Rendering mode (set via npm script, not stored here):
#   ssr  → server-side rendering, requires Node.js server (npm run build / build:ssr)
#   spa  → single-page app, no server, CDN-deployable   (npm run build:spa)
#   ssg  → pre-rendered static HTML, CDN-deployable      (npm run build:ssg)
# Default: ssr
# RENDER_MODE=ssr
